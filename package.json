{
  "name": "auto-complete",
  "version": "0.0.0",
  "description": "Angular Input Autocomplete",
  "license": "MIT",
  "scripts": {
    "ng": "ng",
    "prepare": "husky",
    "generate-build-info": "node scripts/generate-build-info.mjs",
    "postinstall": "node scripts/generate-build-info.mjs",
    "prestart": "node scripts/generate-build-info.mjs",
    "start": "ng serve",
    "test": "ng test",
    "lint": "ng lint",
    "format": "prettier --write \"projects/**/*.{ts,html,scss}\"",
    "format:check": "prettier --check \"projects/**/*.{ts,html,scss}\"",
    "e2e": "ng e2e",
    "build-lib:watch": "ng build auto-complete --watch",
    "build-lib:prod": "ng build auto-complete --configuration production && pnpm run copy-lib",
    "prebuild-docs": "node scripts/generate-build-info.mjs",
    "build-docs": "ng build demo --configuration production",
    "copy-lib": "copyfiles -f LICENSE.md README.md CHANGELOG.md MIGRATION.md dist/",
    "cypress:open": "ng run demo:cypress-open",
    "cypress:run": "ng run demo:cypress-run"
  },
  "private": true,
  "packageManager": "pnpm@11.13.0",
  "lint-staged": {
    "projects/**/*.{ts,html,scss}": "prettier --write"
  },
  "dependencies": {
    "@angular/cdk": "^22.0.4",
    "@angular/common": "^22.0.6",
    "@angular/compiler": "^22.0.6",
    "@angular/core": "^22.0.6",
    "@angular/forms": "^22.0.6",
    "@angular/material": "^22.0.4",
    "@angular/platform-browser": "^22.0.6",
    "@angular/router": "^22.0.6",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^22.0.6",
    "@angular/cli": "^22.0.6",
    "@angular/compiler-cli": "^22.0.6",
    "@angular/language-service": "^22.0.6",
    "@cypress/schematic": "^5.0.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "angular-eslint": "^22.1.0",
    "copyfiles": "^2.4.1",
    "cypress": "^15.18.1",
    "eslint": "^10.7.0",
    "eslint-plugin-cypress": "^6.4.2",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "ng-packagr": "^22.0.1",
    "prettier": "^3.9.5",
    "ts-node": "~10.9.2",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
